NEXT_PUBLIC_SITE_URL=https://hillcountrywellandpump.com
NEXT_PUBLIC_EMAIL=info@hillcountrywellandpump.com

# Optional — only set these if you wire up a Twilio SMS-only number for the website.
# We do NOT take phone calls. The number, if displayed, is text-only and the
# inbound webhook drops messages straight into the CRM via /api/sms-inbound.
NEXT_PUBLIC_TEXT_NUMBER=
NEXT_PUBLIC_TEXT_NUMBER_RAW=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_URL=

# Supabase (lead persistence). Without these, leads go to in-memory and reset on deploy.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin / CRM
ADMIN_PASSWORD=change-this-strong-password
ADMIN_SESSION_SECRET=change-this-32-byte-random-string
